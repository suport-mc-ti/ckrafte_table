# --- GitHub Models -----------------------------------------------
# Crea un token de acceso con permisos minimos para el proveedor que uses.
# Nunca subas el valor real de este archivo a git.
OPENAI_API_KEY=YOUR_API_KEY_HERE
OPENAI_BASE_URL=https://models.inference.ai.azure.com
OPENAI_MODEL=gpt-4o

# Alternativas de modelo:
#   gpt-4o           -> mejor calidad
#   gpt-4o-mini      -> mas rapido y economico
#   Meta-Llama-3.3-70B-Instruct -> sin limite de pago

# --- Preferencias ------------------------------------------------
OUTPUT_LANGUAGE=espanol
OUTPUT_DIR=./output
OPENAI_AGENTS_DISABLE_TRACING=1
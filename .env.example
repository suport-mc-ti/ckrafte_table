# --- Ollama local (recomendado para privacidad) ------------------
OPENAI_PROVIDER=ollama
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=llama3.2
AGENT_MODEL_CONFIG_FILE=shared/agent-models.json

# Si usas proveedor remoto, define una clave real SOLO en tu `.env` local.
# Nunca subas secretos a git.

# --- Preferencias ------------------------------------------------
OUTPUT_LANGUAGE=espanol
OUTPUT_DIR=./output
OPENAI_AGENTS_DISABLE_TRACING=1